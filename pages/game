<!DOCTYPE html>
<html lang="en">
<head> 
    <meta charset="UTF-8">
    <title>Snake game</title>
    <style>
        body {
            background-color: #2c3e50;
            display: flex; /* Centers the canvas nicely */
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            font-family: Arial, sans-serif;
        }
        canvas {
            border: 5px solid #009BFF;
            background-color: #ecf0f1;
            box-shadow: 0px 0px 20px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>
    <canvas id="gameCanvas" width="400" height="400"></canvas>

    <script>
        // 1. Setup Canvas and Variables
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");

        const gridSize = 20;
        let score = 0;
        let dx = gridSize; // Start moving right
        let dy = 0;
        let changingDirection = false; // Prevents the rapid double-keypress bug
        
        // Snake array (coordinate based)
        let snake = [
            {x: 200, y: 200},
            {x: 180, y: 200},
            {x: 160, y: 200}
        ];
        
        let food = {x: 0, y: 0};
        generateFood(); // Generate the first piece of food

        // 2. Main Game Loop
        function main() {
            if (hasGameEnded()) {
                alert("Game Over! Your final score was: " + score);
                document.location.reload(); 
                return;
            }

            changingDirection = false; // Reset the turn lock every frame

            setTimeout(function onTick() {
                clearCanvas();
                drawFood();
                moveSnake();
                drawSnake();
                drawScore(); // Draw the score on top of everything
                main();
            }, 100);
        }

        // 3. Clear the canvas every frame
        function clearCanvas() {
            ctx.fillStyle = "#ecf0f1";
            ctx.fillRect(0, 0, canvas.width, canvas.height);
        }

        // 4. Draw the Score
        function drawScore() {
            ctx.fillStyle = "#2c3e50"; // Dark text color
            ctx.font = "20px Arial";
            ctx.fillText("Score: " + score, 10, 30); // Draw at top-left corner
        }

        // 5. Draw the Snake
        function drawSnake() {
            ctx.fillStyle = "#27ae60";
            ctx.strokeStyle = "#2ecc71";
            snake.forEach(function(part) {
                ctx.fillRect(part.x, part.y, gridSize, gridSize);
                ctx.strokeRect(part.x, part.y, gridSize, gridSize);
            });
        }

        // 6. Move the Snake
        function moveSnake() {
            const head = { x: snake[0].x + dx, y: snake[0].y + dy };
            snake.unshift(head);

            if (head.x === food.x && head.y === food.y) {
                score += 10;
                generateFood();
            } else {
                snake.pop(); // Remove tail if no food eaten
            }
        }

        // 7. Draw Food
        function drawFood() {
            ctx.fillStyle = "#e74c3c"; 
            ctx.strokeStyle = "#c0392b";
            ctx.fillRect(food.x, food.y, gridSize, gridSize);
            ctx.strokeRect(food.x, food.y, gridSize, gridSize);
        }

        // 8. Generate Food
        function randomTen(min, max) {
            return Math.round((Math.random() * (max - min) + min) / gridSize) * gridSize;
        }

        function generateFood() {
            food.x = randomTen(0, canvas.width - gridSize);
            food.y = randomTen(0, canvas.height - gridSize);
            
            snake.forEach(function has_snake_eaten_food(part) {
                const has_eaten = part.x === food.x && part.y === food.y;
                if (has_eaten) generateFood();
            });
        }

        // 9. Controls
        document.addEventListener("keydown", changeDirection);

        function changeDirection(event) {
            const LEFT_KEY = 37;
            const RIGHT_KEY = 39;
            const UP_KEY = 38;
            const DOWN_KEY = 40;

            // Prevent turning twice in one frame
            if (changingDirection) return;

            const keyPressed = event.keyCode;
            const goingUp = dy === -gridSize;
            const goingDown = dy === gridSize;
            const goingRight = dx === gridSize;
            const goingLeft = dx === -gridSize;

            if (keyPressed === LEFT_KEY && !goingRight) {
                dx = -gridSize; dy = 0; changingDirection = true;
            }
            if (keyPressed === UP_KEY && !goingDown) {
                dx = 0; dy = -gridSize; changingDirection = true;
            }
            if (keyPressed === RIGHT_KEY && !goingLeft) {
                dx = gridSize; dy = 0; changingDirection = true;
            }
            if (keyPressed === DOWN_KEY && !goingUp) {
                dx = 0; dy = gridSize; changingDirection = true;
            }
        }

        // 10. Game Over Conditions
        function hasGameEnded() {
            for (let i = 4; i < snake.length; i++) {
                if (snake[i].x === snake[0].x && snake[i].y === snake[0].y) return true;
            }
            
            const hitLeftWall = snake[0].x < 0;
            const hitRightWall = snake[0].x >= canvas.width;
            const hitTopWall = snake[0].y < 0;
            const hitBottomWall = snake[0].y >= canvas.height;

            return hitLeftWall || hitRightWall || hitTopWall || hitBottomWall;
        }

        // Start the game
        main();
    </script>
</body>
</html>
